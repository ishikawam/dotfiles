      "mcp__notion__API-post-search",
      "mcp__notion__API-get-self",
      "mcp__claude-in-chrome__read_network_requests",
      "mcp__claude-in-chrome__read_console_messages",
      "mcp__claude-in-chrome__read_page",
      "mcp__claude-in-chrome__get_page_text",
      "mcp__claude-in-chrome__find",
      "mcp__claude-in-chrome__tabs_context_mcp"
    ],
    "deny": [
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.cwd // \"\"' | { read -r cwd; name=$(basename \"${cwd:-Claude Code}\"); afplay /System/Library/Sounds/Ping.aiff & osascript -e \"display notification \\\"作業が完了しました\\\" with title \\\"Claude Code: $name\\\"\"; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[.cwd // \"\", .message // \"\"] | @tsv' | { IFS=$'\\t' read -r cwd message; name=$(basename \"${cwd:-Claude Code}\"); osascript -e \"display notification \\\"${message:-入力待ちです}\\\" with title \\\"Claude Code: $name\\\"\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
