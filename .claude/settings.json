      "Bash(for:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr:*)",
      "Bash(git --version)",
      "Bash(git -C ~ diff --cached)",
      "Bash(git -C ~ log:*)",
      "Bash(git -C ~ status)",
      "Bash(git commit:*)",
      "Bash(git grep:*)",
      "Bash(go build:*)",
      "Bash(go env:*)",
      "Bash(go get:*)",
      "Bash(go mod:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(goenv --version:*)",
