      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(nodenv local:*)",
      "Bash(nodenv versions:*)",
      "Bash(npm help:*)",
      "Bash(npm install)",
      "Bash(npx marp:*)",
      "Bash(open:*)",
      "Bash(osascript:*)",
      "Bash(pandoc:*)",
