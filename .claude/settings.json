      "Bash(sw_vers:*)",
      "Bash(system_profiler:*)",
      "Bash(tail:*)",
      "Bash(terraform init:*)",
      "Bash(terraform version)",
      "Bash(time make:*)",
      "Bash(timeout:*)",
      "Bash(true)",
      "Bash(weasyprint:*)",
      "Bash(whisper:*)",
      "Bash(xattr:*)",
      "Bash(xcode-select:*)",
      "Bash(xxd:*)",
      "Bash(zsh:*)",
      "Edit",
      "Read",
      "WebFetch(domain:)",
      "WebFetch(domain:console.wafcharm.com)",
      "WebFetch(domain:dev.classmethod.jp)",
      "WebFetch(domain:developer.nulab.com)",
